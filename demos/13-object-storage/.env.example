# Demo 13 — object storage gate (non-secret placeholders only).
# Copied into the environment by run.sh; safe to commit values below.

FORGE_AUTH_MODE=dev
FORGE_STORAGE_SIGNING_KEY=demo-13-signing-key-not-a-secret
FORGE_STORAGE_CLOCK_SKEW_SECONDS=0
FORGE_STORAGE_MAX_TTL_SECONDS=3600
FORGE_STORAGE_DEFAULT_QUOTA_BYTES=1073741824
FORGE_LOG_LEVEL=info

# Host URL used by acceptance.sh (published compose port).
FORGE_STORAGE_URL=http://127.0.0.1:4107
FORGE_STORAGE_PROJECT=demo-13
