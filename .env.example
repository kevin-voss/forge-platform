# Forge Platform local development environment
# Copy to .env and adjust as needed. Never commit .env.

FORGE_ENV=local
FORGE_LOG_LEVEL=info

# PostgreSQL (host port 5001)
POSTGRES_USER=forge
POSTGRES_PASSWORD=forge
POSTGRES_DB=forge
FORGE_DATABASE_URL=postgres://forge:forge@localhost:5001/forge?sslmode=disable

# Forge Secrets (host port 4104) — base64-encoded 32-byte master key (local-dev default)
FORGE_SECRETS_MASTER_KEY=bG9jYWwtZGV2LWZvcmdlLXNlY3JldHMta2V5ISEhISE=
FORGE_SECRETS_MASTER_KEY_ID=m1
FORGE_SECRETS_DB_URL=postgres://forge:forge@localhost:5001/forge_secrets

# Forge Storage (host port 4107)
FORGE_STORAGE_ROOT=/data/storage
FORGE_STORAGE_ALLOWED_BASE=/data

# NATS (host port 5002)
FORGE_EVENTS_URL=nats://localhost:5002

# Local OCI registry (host port 5000)
FORGE_REGISTRY_URL=localhost:5000

# OpenTelemetry Collector
FORGE_OTEL_ENDPOINT=http://localhost:4318

# Dashboards
GRAFANA_URL=http://localhost:3000
PROMETHEUS_URL=http://localhost:3001
TEMPO_URL=http://localhost:3002
LOKI_URL=http://localhost:3003
