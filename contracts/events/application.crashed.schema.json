{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forge.local/contracts/events/application.crashed/v1",
  "title": "application.crashed",
  "description": "Emitted when an application workload crashes or exits unexpectedly.",
  "x-forge-subject": "application.crashed",
  "x-forge-schema-version": 1,
  "type": "object",
  "additionalProperties": false,
  "required": ["service", "reason", "occurred_at"],
  "properties": {
    "service": {
      "type": "string",
      "minLength": 1,
      "description": "Service name that crashed"
    },
    "reason": {
      "type": "string",
      "minLength": 1,
      "description": "Crash reason (e.g. oom, exit, signal)"
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time",
      "description": "When the crash was observed (RFC 3339)"
    },
    "exit_code": {
      "type": "integer"
    },
    "node_id": {
      "type": "string"
    },
    "deployment_id": {
      "type": "string"
    }
  }
}
