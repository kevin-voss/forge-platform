PORT=4107
FORGE_SERVICE_NAME=forge-storage
FORGE_SERVICE_VERSION=0.1.0
FORGE_LOG_LEVEL=info
FORGE_ENV=development
FORGE_SHUTDOWN_GRACE_SECONDS=10
FORGE_STORAGE_ROOT=.tmp/forge-storage
FORGE_STORAGE_ALLOWED_BASE=.tmp
FORGE_STORAGE_META_PATH=.tmp/forge-storage/meta/index.db
FORGE_STORAGE_STREAM_BUFFER_BYTES=65536
# FORGE_STORAGE_MAX_OBJECT_BYTES=1073741824
FORGE_STORAGE_SIGNING_KEY=dev-only-signing-key-change-me
# FORGE_STORAGE_SIGNING_KEY_PREV=
FORGE_STORAGE_MAX_TTL_SECONDS=3600
FORGE_STORAGE_CLOCK_SKEW_SECONDS=30
FORGE_AUTH_MODE=dev
