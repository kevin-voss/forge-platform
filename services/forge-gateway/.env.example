PORT=8080
FORGE_SERVICE_NAME=forge-gateway
FORGE_SERVICE_VERSION=0.1.0
FORGE_LOG_LEVEL=info
FORGE_ENV=development
FORGE_AUTH_MODE=dev
FORGE_SHUTDOWN_GRACE_SECONDS=10
# Optional JSON route array bootstrap (see README):
# FORGE_GATEWAY_STATIC_ROUTES=/etc/forge/routes.json

# Route sync from platform state (05.03)
FORGE_CONTROL_URL=http://forge-control:8080
FORGE_RUNTIME_URL=http://forge-runtime:8080
FORGE_ROUTE_SOURCE=control
# Required when FORGE_ROUTE_SOURCE=discovery (21.05). Unused for control/runtime.
FORGE_DISCOVERY_URL=http://forge-discovery:8080
FORGE_ROUTE_SYNC_INTERVAL_SECONDS=10
FORGE_HOST_PATTERN={service}.{project}.demo.localhost
# Host paired with Runtime-published ports when building upstream URLs (interim source).
# Use 127.0.0.1 for host-network/local; Compose uses host.docker.internal.
FORGE_UPSTREAM_HOST=127.0.0.1

# Health-aware upstreams (05.04)
FORGE_UPSTREAM_PROBE_INTERVAL_SECONDS=5
FORGE_UPSTREAM_PROBE_PATH=/health/ready
FORGE_UPSTREAM_FAILURE_THRESHOLD=3
FORGE_UPSTREAM_SUCCESS_THRESHOLD=2
FORGE_UPSTREAM_TRUST_RUNTIME_STATUS=true

# Request IDs, forwarded headers, timeouts (05.05)
FORGE_REQUEST_ID_HEADER=X-Request-Id
FORGE_PROXY_CONNECT_TIMEOUT_SECONDS=5
FORGE_PROXY_RESPONSE_HEADER_TIMEOUT_SECONDS=15
FORGE_PROXY_OVERALL_TIMEOUT_SECONDS=30
FORGE_TRUST_INBOUND_XFF=false

# WebSocket + SSE proxy (05.06)
FORGE_WS_ENABLED=true
FORGE_SSE_ENABLED=true
FORGE_WS_IDLE_TIMEOUT_SECONDS=300
FORGE_STREAM_READ_TIMEOUT_SECONDS=0
