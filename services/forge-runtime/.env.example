PORT=8080
FORGE_SERVICE_NAME=forge-runtime
FORGE_SERVICE_VERSION=0.1.0
FORGE_LOG_LEVEL=info
FORGE_ENV=development
FORGE_AUTH_MODE=dev
DOCKER_HOST=unix:///var/run/docker.sock
FORGE_SHUTDOWN_GRACE_SECONDS=10
FORGE_DOCKER_STARTUP_RETRIES=5
FORGE_DOCKER_STARTUP_RETRY_DELAY_MS=500
FORGE_RUNTIME_DATA_DIR=/var/lib/forge-runtime
FORGE_HEARTBEAT_INTERVAL_SECONDS=10
FORGE_PULL_TIMEOUT_SECONDS=120
FORGE_DEFAULT_REGISTRY=localhost:5000
FORGE_PROBE_INTERVAL_SECONDS=5
FORGE_PROBE_TIMEOUT_SECONDS=2
FORGE_PROBE_FAILURE_THRESHOLD=3
FORGE_PROBE_READY_PATH=/health/ready
FORGE_PROBE_LIVE_PATH=/health/live
# Host paired with published host ports when container IP is unavailable.
# In Compose use host.docker.internal (see compose.yaml extra_hosts).
FORGE_PROBE_HOST=127.0.0.1
FORGE_LOG_DEFAULT_TAIL=100
FORGE_LOG_STREAM_BUFFER=8192
# Reserved for 04.07 — registration stub is a no-op when unset:
# FORGE_CONTROL_URL=http://forge-control:8080
