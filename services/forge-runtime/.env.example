PORT=8080
FORGE_SERVICE_NAME=forge-runtime
FORGE_SERVICE_VERSION=0.1.0
FORGE_LOG_LEVEL=info
FORGE_ENV=development
FORGE_AUTH_MODE=dev
DOCKER_HOST=unix:///var/run/docker.sock
FORGE_SHUTDOWN_GRACE_SECONDS=10
FORGE_DOCKER_STARTUP_RETRIES=5
FORGE_DOCKER_STARTUP_RETRY_DELAY_MS=500
FORGE_RUNTIME_DATA_DIR=/var/lib/forge-runtime
FORGE_HEARTBEAT_INTERVAL_SECONDS=10
FORGE_PULL_TIMEOUT_SECONDS=120
FORGE_DEFAULT_REGISTRY=localhost:5000
FORGE_PROBE_INTERVAL_SECONDS=5
FORGE_PROBE_TIMEOUT_SECONDS=2
FORGE_PROBE_FAILURE_THRESHOLD=3
FORGE_PROBE_READY_PATH=/health/ready
FORGE_PROBE_LIVE_PATH=/health/live
# Host paired with published host ports when container IP is unavailable.
# In Compose use host.docker.internal (see compose.yaml extra_hosts).
FORGE_PROBE_HOST=127.0.0.1
FORGE_LOG_DEFAULT_TAIL=100
FORGE_LOG_STREAM_BUFFER=8192
FORGE_STOP_GRACE_SECONDS=10
# recreate (default) or reject → 409 on image/config conflict
FORGE_ON_CONFIG_CONFLICT=recreate
# Control desired→actual reconcile (unset disables the loop):
FORGE_CONTROL_URL=http://forge-control:8080
FORGE_RECONCILE_INTERVAL_SECONDS=10
# push = POST /v1/deployments/{id}/status (404 tolerated); pull = GET /v1/node/state only
FORGE_CONTROL_REPORT_MODE=push
# runtime = local converge create/stop; control = epic 07 Control reconciler owns lifecycle
FORGE_LIFECYCLE_OWNER=runtime
# Epic 21.02: Discovery lease registration (unset FORGE_DISCOVERY_URL to disable)
FORGE_DISCOVERY_URL=http://forge-discovery:8080
FORGE_DISCOVERY_REGISTER_ENABLED=true
FORGE_DISCOVERY_LEASE_SECONDS=20
FORGE_DISCOVERY_DEFAULT_PROJECT=demo
FORGE_DISCOVERY_DEFAULT_ENVIRONMENT=local
# Epic 22.03/22.04: network peer poll + transport modes (unset FORGE_NETWORK_URL to disable)
FORGE_NETWORK_URL=http://forge-network:8080
FORGE_NETWORK_NAME=cluster-overlay
FORGE_NETWORK_WG_BACKEND=auto
FORGE_NETWORK_WG_IFACE=wg0
# FORGE_NETWORK_WG_ENDPOINT=203.0.113.5:51820
FORGE_NETWORK_PEER_POLL_INTERVAL_S=5
FORGE_NODE_DOCKER_COLOCATED=true
# FORGE_NODE_NETWORK_MEMBERSHIP=hetzner-private-fsn1
FORGE_NETWORK_PRIVATE_IFACE=eth0
FORGE_NETWORK_ROUTE_BACKEND=host
