PORT=8080
FORGE_SERVICE_NAME=forge-control
FORGE_SERVICE_VERSION=0.1.0
FORGE_LOG_LEVEL=info
FORGE_OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
FORGE_ENV=development
FORGE_AUTH_MODE=enforce
FORGE_IDENTITY_URL=http://127.0.0.1:4002
FORGE_INTROSPECT_CACHE_TTL_S=10
FORGE_AUTHZ_CACHE_TTL_S=10
FORGE_SHUTDOWN_GRACE_SECONDS=10
DATABASE_URL=jdbc:postgresql://127.0.0.1:5001/forge
DATABASE_USER=forge
DATABASE_PASSWORD=forge
DATABASE_SCHEMA=control
DATABASE_POOL_MAX=10
DATABASE_MIGRATE_ON_START=true
FORGE_RECONCILE_ENABLED=true
FORGE_RECONCILE_INTERVAL_MS=2000
FORGE_RECONCILE_MAX_ACTIONS_PER_TICK=5
FORGE_RUNTIME_URL=http://forge-runtime:4102
FORGE_GATEWAY_URL=http://forge-gateway:4000
# FORGE_ROLLOUT_BATCH_SIZE=1
# FORGE_ROLLOUT_TIMEOUT_S=120
FORGE_ROLLBACK_ENABLED=true
FORGE_READINESS_POLL_MS=1000
FORGE_READINESS_MAX_WAIT_S=60
FORGE_HISTORY_ENABLED=true
FORGE_STARTUP_ADOPT_LABELS=true
FORGE_SCHEDULER_ENABLED=true
FORGE_SCHEDULER_STRATEGY=least-allocated
FORGE_SCHEDULER_LOCAL_NODE_ID=node-local
FORGE_DB_PROVISIONER=fake
FORGE_DB_MANAGED_NETWORK=forge-net
FORGE_DB_POSTGRES_IMAGE=postgres:16
FORGE_DB_ENDPOINT_HOST=127.0.0.1
FORGE_DB_ROTATION_GRACE_SECONDS=60
FORGE_DB_PREDELETE_BACKUP=true
