PORT=8080
FORGE_SERVICE_NAME=forge-discovery
FORGE_SERVICE_VERSION=0.1.0
FORGE_LOG_LEVEL=info
FORGE_ENV=development
FORGE_AUTH_MODE=dev
FORGE_SHUTDOWN_GRACE_SECONDS=10
FORGE_DATABASE_URL=postgres://forge:forge@127.0.0.1:5001/forge?sslmode=disable
FORGE_DATABASE_SCHEMA=discovery
FORGE_DATABASE_POOL_MAX=10
FORGE_DATABASE_MIGRATE_ON_START=true
FORGE_CONTROL_URL=http://127.0.0.1:4001
FORGE_DISCOVERY_LEASE_SECONDS_DEFAULT=20
FORGE_DISCOVERY_SWEEP_INTERVAL_SECONDS=5
FORGE_DISCOVERY_REAP_AFTER_SECONDS=300
FORGE_DISCOVERY_NODE_WATCH_RESYNC_SECONDS=30
FORGE_DISCOVERY_DNS_ENABLED=true
FORGE_DISCOVERY_DNS_PORT=5053
FORGE_DISCOVERY_DNS_ZONE=svc.forge
FORGE_DISCOVERY_DNS_TTL_SECONDS=5
FORGE_DISCOVERY_DNS_NEGATIVE_TTL_SECONDS=2
FORGE_DISCOVERY_DNS_FORWARD_UPSTREAM=127.0.0.11
FORGE_DISCOVERY_DNS_FORWARD_TIMEOUT_MS=2000
FORGE_OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
