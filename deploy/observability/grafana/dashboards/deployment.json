    {
      "id": 5,
      "type": "timeseries",
      "title": "Per-deployment error rate",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 16
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(forge_http_requests_total{http_status_class=\"5xx\", forge_deployment=~\"${forge.deployment:regex}\"}[5m])) by (forge_deployment) / clamp_min(sum(rate(forge_http_requests_total{forge_deployment=~\"${forge.deployment:regex}\"}[5m])) by (forge_deployment), 1e-9)",
          "legendFormat": "{{forge_deployment}}",
          "range": true,
