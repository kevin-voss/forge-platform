{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "types": ["node"],
    "rootDir": ".",
    "outDir": "."
  },
  "include": ["harness/**/*.ts", "projects/**/*.ts", "playwright.config.ts"],
  "exclude": ["node_modules", "artifacts"]
}
